    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin rpy="0 0 0" xyz="0.4 0 0.0"/>
  </joint>
  <!-- =========
       Depth sensor (downward)
       ========= -->
  <link name="depth_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 -0.2"/>
