  </link>
  <joint name="depth_joint" type="fixed">
    <parent link="base_link"/>
    <child link="depth_link"/>
    <origin rpy="0 0 0" xyz="0 0 -0.2"/>
  </joint>
  <link name="thruster_left_link">
    <visual>
      <origin rpy="0 0 0" xyz="0.0  0.3 0.0"/>
      <geometry>
        <cylinder length="0.15" radius="0.05"/>
      </geometry>
      <material name="thruster_color">
        <color rgba="0.2 0.2 0.2 1.0"/>
