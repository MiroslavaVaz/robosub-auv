  <joint name="thruster_vert_joint" type="fixed">
    <parent link="base_link"/>
    <child link="thruster_vert_link"/>
    <origin rpy="0 0 0" xyz="0.0 0.0 0.3"/>
  </joint>
  
  <!-- ======================
       Gazebo-specific plugins
       ====================== -->
  <!-- Hydrodynamics / buoyancy (example for uuv_simulator) -->
  <gazebo>
    <plugin filename="libuuv_gazebo_underwater_plugin.so" name="uuv_underwater_plugin">
      <reference_link>base_link</reference_link>
      <fluid_density>997.0</fluid_density>
      <!-- kg/m^3 -->
      <use_linear_damping>true</use_linear_damping>
      <use_quadratic_damping>true</use_quadratic_damping>
    </plugin>
  </gazebo>
  <!-- IMU plugin -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>50.0</update_rate>
      <visualize>false</visualize>
      <topic>/imu</topic>
      <plugin filename="libgazebo_ros_imu.so" name="imu_plugin"/>
    </sensor>
  </gazebo>
  <!-- Camera plugin -->
  <gazebo reference="camera_link">
    <sensor name="front_camera" type="camera">
      <always_on>true</always_on>
      <update_rate>15.0</update_rate>
      <visualize>false</visualize>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <!-- ~60 deg -->
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>20.0</far>
        </clip>
      </camera>
      <plugin filename="libgazebo_ros_camera.so" name="camera_plugin">
        <always_on>true</always_on>
        <update_rate>15.0</update_rate>
        <camera_name>front_camera</camera_name>
        <image_topic_name>/camera/image_raw</image_topic_name>
        <frame_name>camera_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>
  <!-- Depth / range sensor (simple ray-based) -->
  <gazebo reference="depth_link">
    <sensor name="depth_sensor" type="ray">
      <always_on>true</always_on>
      <update_rate>10.0</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0.0</min_angle>
            <max_angle>0.0</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.0</min>
          <max>50.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <plugin filename="libgazebo_ros_ray_sensor.so" name="depth_plugin">
        <output_type>sensor_msgs/Range</output_type>
        <frame_name>depth_link</frame_name>
        <topic_name>/depth</topic_name>
      </plugin>
    </sensor>
  </gazebo>
  <!-- Thruster plugins (example topics; adjust plugin filenames to your system) -->
  <gazebo reference="thruster_left_link">
    <plugin filename="libuuv_gazebo_thruster_plugin.so" name="left_thruster_plugin">
      <command_topic>/thruster_left</command_topic>
      <thrust_force>0.0</thrust_force>
    </plugin>
  </gazebo>
  <gazebo reference="thruster_right_link">
    <plugin filename="libuuv_gazebo_thruster_plugin.so" name="right_thruster_plugin">
      <command_topic>/thruster_right</command_topic>
      <thrust_force>0.0</thrust_force>
    </plugin>
  </gazebo>
  <gazebo reference="thruster_vert_link">
    <plugin filename="libuuv_gazebo_thruster_plugin.so" name="vert_thruster_plugin">
      <command_topic>/thruster_vertical</command_topic>
      <thrust_force>0.0</thrust_force>
    </plugin>
  </gazebo>
</robot>
