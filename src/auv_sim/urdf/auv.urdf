      <geometry>
        <cylinder length="1.2" radius="0.3"/>
      </geometry>
    </collision>
    <!-- Ix = Iy = (1/12)*m*(3r^2 + L^2), Iz = (1/2)*m*r^2 -->
    <inertial>
      <mass value="25.0"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="3.5624999999999996" ixy="0.0" ixz="0.0" iyy="3.5624999999999996" iyz="0.0" izz="1.125"/>
