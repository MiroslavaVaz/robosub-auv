<?xml version="1.0"?>
<robot name="auv_proxy">

  <!-- =================
       BASE LINK (proxy body + frame)
       ================= -->
  <link name="base_link">
    <inertial>
      <mass value="25.0"/>
      <origin xyz="0 0 0.20" rpy="0 0 0"/>
      <inertia ixx="2.0" ixy="0" ixz="0" iyy="2.0" iyz="0" izz="2.0"/>
    </inertial>

    <!-- collision: simple box -->
    <collision>
      <origin xyz="0 0 0.20" rpy="0 0 0"/>
      <geometry>
        <box size="1.10 0.70 0.40"/>
      </geometry>
    </collision>

    <!-- ====== Center tubes (stacked) ====== -->
    <visual>
      <origin xyz="0 0 0.28" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.11" length="0.95"/></geometry>
      <material name="tube"><color rgba="0.92 0.92 0.92 1"/></material>
    </visual>
    <visual>
      <origin xyz="0 0 0.12" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.11" length="0.95"/></geometry>
      <material name="tube"/>
    </visual>

    <!-- Clear canister (middle) -->
    <visual>
      <origin xyz="0 0 0.20" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.14" length="0.55"/></geometry>
      <material name="clear"><color rgba="0.75 0.85 0.95 0.25"/></material>
    </visual>

    <!-- ====== Perimeter rails (TOP rectangle: 4 rails) ======
         Rectangle dimensions: length_x=1.05, width_y=0.70
         Rails at z=0.40
    -->
    <!-- Top: front/back rails (along X) -->
    <visual>
      <origin xyz="0 0.35 0.40" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.045" length="1.05"/></geometry>
      <material name="pvc"><color rgba="0.95 0.95 0.95 1"/></material>
    </visual>
    <visual>
      <origin xyz="0 -0.35 0.40" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.045" length="1.05"/></geometry>
      <material name="pvc"/>
    </visual>
    <!-- Top: left/right rails (along Y) -->
    <visual>
      <origin xyz="0.525 0 0.40" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.045" length="0.70"/></geometry>
      <material name="pvc"/>
    </visual>
    <visual>
      <origin xyz="-0.525 0 0.40" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.045" length="0.70"/></geometry>
      <material name="pvc"/>
    </visual>

    <!-- ====== Perimeter rails (BOTTOM rectangle: 4 rails) ======
         Rails at z=0.02
    -->
    <!-- Bottom: front/back rails (along X) -->
    <visual>
      <origin xyz="0 0.35 0.02" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.045" length="1.05"/></geometry>
      <material name="pvc"/>
    </visual>
    <visual>
      <origin xyz="0 -0.35 0.02" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.045" length="1.05"/></geometry>
      <material name="pvc"/>
    </visual>
    <!-- Bottom: left/right rails (along Y) -->
    <visual>
      <origin xyz="0.525 0 0.02" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.045" length="0.70"/></geometry>
      <material name="pvc"/>
    </visual>
    <visual>
      <origin xyz="-0.525 0 0.02" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.045" length="0.70"/></geometry>
      <material name="pvc"/>
    </visual>

    <!-- Upright posts (4 corners) -->
    <visual><origin xyz="0.525 0.35 0.21" rpy="0 0 0"/><geometry><cylinder radius="0.045" length="0.42"/></geometry><material name="pvc"/></visual>
    <visual><origin xyz="0.525 -0.35 0.21" rpy="0 0 0"/><geometry><cylinder radius="0.045" length="0.42"/></geometry><material name="pvc"/></visual>
    <visual><origin xyz="-0.525 0.35 0.21" rpy="0 0 0"/><geometry><cylinder radius="0.045" length="0.42"/></geometry><material name="pvc"/></visual>
    <visual><origin xyz="-0.525 -0.35 0.21" rpy="0 0 0"/><geometry><cylinder radius="0.045" length="0.42"/></geometry><material name="pvc"/></visual>

  </link>

  <!-- =================
       CAMERA + IMU markers
       ================= -->
  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.06"/></geometry>
      <material name="cam"><color rgba="0.10 0.10 0.10 1"/></material>
    </visual>
    <inertial><mass value="0.1"/><origin xyz="0 0 0"/><inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/></inertial>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.40 0 0.26" rpy="0 0 0"/>
  </joint>

  <link name="imu_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
      <material name="imu"><color rgba="0.10 0.75 0.20 1"/></material>
    </visual>
    <inertial><mass value="0.05"/><origin xyz="0 0 0"/><inertia ixx="5e-5" ixy="0" ixz="0" iyy="5e-5" iyz="0" izz="5e-5"/></inertial>
  </link>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.44" rpy="0 0 0"/>
  </joint>

  <!-- =================
       THRUSTER BODY + SPINNING PROPELLER (no meshes)
       ================= -->
  <!-- Thruster body: cylinder. Propeller: hub + 3 blades, spinning on continuous joint. -->

  <!-- Macro-like pattern done manually 7 times for speed -->

  <!-- ===== LEFT 1 ===== -->
  <link name="thruster_L1_body">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 1.5708"/>
      <geometry><cylinder radius="0.045" length="0.18"/></geometry>
      <material name="thr"><color rgba="0.25 0.25 0.25 1"/></material>
    </visual>
  </link>
  <joint name="thruster_L1_body_joint" type="fixed">
    <parent link="base_link"/><child link="thruster_L1_body"/>
    <origin xyz="0.30 0.38 0.10" rpy="0 0 0"/>
  </joint>

  <link name="prop_L1">
    <!-- hub -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.018" length="0.02"/></geometry>
      <material name="prop"><color rgba="0.05 0.05 0.05 1"/></material>
    </visual>
    <!-- 3 blades -->
    <visual><origin xyz="0.03 0 0" rpy="0 0 0"/><geometry><box size="0.06 0.012 0.003"/></geometry><material name="prop"/></visual>
    <visual><origin xyz="0.03 0 0" rpy="0 0 2.0944"/><geometry><box size="0.06 0.012 0.003"/></geometry><material name="prop"/></visual>
    <visual><origin xyz="0.03 0 0" rpy="0 0 4.1888"/><geometry><box size="0.06 0.012 0.003"/></geometry><material name="prop"/></visual>
  </link>
  <joint name="prop_L1_joint" type="continuous">
    <parent link="thruster_L1_body"/><child link="prop_L1"/>
    <origin xyz="0.10 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
  </joint>

  <!-- ===== LEFT 2 ===== -->
  <link name="thruster_L2_body"><visual><origin xyz="0 0 0" rpy="0 0 1.5708"/><geometry><cylinder radius="0.045" length="0.18"/></geometry><material name="thr"/></visual></link>
  <joint name="thruster_L2_body_joint" type="fixed"><parent link="base_link"/><child link="thruster_L2_body"/><origin xyz="0.00 0.38 0.10" rpy="0 0 0"/></joint>

  <link name="prop_L2">
    <visual><origin xyz="0 0 0"/><geometry><cylinder radius="0.018" length="0.02"/></geometry><material name="prop"/></visual>
    <visual><origin xyz="0.03 0 0" rpy="0 0 0"/><geometry><box size="0.06 0.012 0.003"/></geometry><material name="prop"/></visual>
    <visual><origin xyz="0.03 0 0" rpy="0 0 2.0944"/><geometry><box size="0.06 0.012 0.003"/></geometry><material name="prop"/></visual>
    <visual><origin xyz="0.03 0 0" rpy="0 0 4.1888"/><geometry><box size="0.06 0.012 0.003"/></geometry><material name="prop"/></visual>
  </link>
  <joint name="prop_L2_joint" type="continuous"><parent link="thruster_L2_body"/><child link="prop_L2"/><origin xyz="0.10 0 0"/><axis xyz="1 0 0"/></joint>

  <!-- ===== LEFT 3 ===== -->
  <link name="thruster_L3_body"><visual><origin xyz="0 0 0" rpy="0 0 1.5708"/><geometry><cylinder radius="0.045" length="0.18"/></geometry><material name="thr"/></visual></link>
  <joint name="thruster_L3_body_joint" type="fixed"><parent link="base_link"/><child link="thruster_L3_body"/><origin xyz="-0.30 0.38 0.10" rpy="0 0 0"/></joint>

  <link name="prop_L3">
    <visual><origin xyz="0 0 0"/><geometry><cylinder radius="0.018" length="0.02"/></geometry><material name="prop"/></visual>
    <visual><origin xyz="0.03 0 0" rpy="0 0 0"/><geometry><box size="0.06 0.012 0.003"/></geometry><material name="prop"/></visual>
    <visual><origin xyz="0.03 0 0" rpy="0 0 2.0944"/><geometry><box size="0.06 0.012 0.003"/></geometry><material name="prop"/></visual>
    <visual><origin xyz="0.03 0 0" rpy="0 0 4.1888"/><geometry><box size="0.06 0.012 0.003"/></geometry><material name="prop"/></visual>
  </link>
  <joint name="prop_L3_joint" type="continuous"><parent link="thruster_L3_body"/><child link="prop_L3"/><origin xyz="0.10 0 0"/><axis xyz="1 0 0"/></joint>

  <!-- ===== RIGHT 1 ===== -->
  <link name="thruster_R1_body"><visual><origin xyz="0 0 0" rpy="0 0 -1.5708"/><geometry><cylinder radius="0.045" length="0.18"/></geometry><material name="thr"/></visual></link>
  <joint name="thruster_R1_body_joint" type="fixed"><parent link="base_link"/><child link="thruster_R1_body"/><origin xyz="0.30 -0.38 0.10" rpy="0 0 0"/></joint>

  <link name="prop_R1">
    <visual><origin xyz="0 0 0"/><geometry><cylinder radius="0.018" length="0.02"/></geometry><material name="prop"/></visual>
    <visual><origin xyz="0.03 0 0" rpy="0 0 0"/><geometry><box size="0.06 0.012 0.003"/></geometry><material name="prop"/></visual>
    <visual><origin xyz="0.03 0 0" rpy="0 0 2.0944"/><geometry><box size="0.06 0.012 0.003"/></geometry><material name="prop"/></visual>
    <visual><origin xyz="0.03 0 0" rpy="0 0 4.1888"/><geometry><box size="0.06 0.012 0.003"/></geometry><material name="prop"/></visual>
  </link>
  <joint name="prop_R1_joint" type="continuous"><parent link="thruster_R1_body"/><child link="prop_R1"/><origin xyz="0.10 0 0"/><axis xyz="1 0 0"/></joint>

  <!-- ===== RIGHT 2 ===== -->
  <link name="thruster_R2_body"><visual><origin xyz="0 0 0" rpy="0 0 -1.5708"/><geometry><cylinder radius="0.045" length="0.18"/></geometry><material name="thr"/></visual></link>
  <joint name="thruster_R2_body_joint" type="fixed"><parent link="base_link"/><child link="thruster_R2_body"/><origin xyz="0.00 -0.38 0.10" rpy="0 0 0"/></joint>

  <link name="prop_R2">
    <visual><origin xyz="0 0 0"/><geometry><cylinder radius="0.018" length="0.02"/></geometry><material name="prop"/></visual>
    <visual><origin xyz="0.03 0 0" rpy="0 0 0"/><geometry><box size="0.06 0.012 0.003"/></geometry><material name="prop"/></visual>
    <visual><origin xyz="0.03 0 0" rpy="0 0 2.0944"/><geometry><box size="0.06 0.012 0.003"/></geometry><material name="prop"/></visual>
    <visual><origin xyz="0.03 0 0" rpy="0 0 4.1888"/><geometry><box size="0.06 0.012 0.003"/></geometry><material name="prop"/></visual>
  </link>
  <joint name="prop_R2_joint" type="continuous"><parent link="thruster_R2_body"/><child link="prop_R2"/><origin xyz="0.10 0 0"/><axis xyz="1 0 0"/></joint>

  <!-- ===== RIGHT 3 ===== -->
  <link name="thruster_R3_body"><visual><origin xyz="0 0 0" rpy="0 0 -1.5708"/><geometry><cylinder radius="0.045" length="0.18"/></geometry><material name="thr"/></visual></link>
  <joint name="thruster_R3_body_joint" type="fixed"><parent link="base_link"/><child link="thruster_R3_body"/><origin xyz="-0.30 -0.38 0.10" rpy="0 0 0"/></joint>

  <link name="prop_R3">
    <visual><origin xyz="0 0 0"/><geometry><cylinder radius="0.018" length="0.02"/></geometry><material name="prop"/></visual>
    <visual><origin xyz="0.03 0 0" rpy="0 0 0"/><geometry><box size="0.06 0.012 0.003"/></geometry><material name="prop"/></visual>
    <visual><origin xyz="0.03 0 0" rpy="0 0 2.0944"/><geometry><box size="0.06 0.012 0.003"/></geometry><material name="prop"/></visual>
    <visual><origin xyz="0.03 0 0" rpy="0 0 4.1888"/><geometry><box size="0.06 0.012 0.003"/></geometry><material name="prop"/></visual>
  </link>
  <joint name="prop_R3_joint" type="continuous"><parent link="thruster_R3_body"/><child link="prop_R3"/><origin xyz="0.10 0 0"/><axis xyz="1 0 0"/></joint>

  <!-- ===== BACK THRUSTER ===== -->
  <link name="thruster_back_body">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.045" length="0.18"/></geometry>
      <material name="thr"/>
    </visual>
  </link>
  <joint name="thruster_back_body_joint" type="fixed">
    <parent link="base_link"/><child link="thruster_back_body"/>
    <origin xyz="-0.55 0 0.14" rpy="0 0 0"/>
  </joint>

  <link name="prop_back">
    <visual><origin xyz="0 0 0"/><geometry><cylinder radius="0.018" length="0.02"/></geometry><material name="prop"/></visual>
    <visual><origin xyz="0.03 0 0" rpy="0 0 0"/><geometry><box size="0.06 0.012 0.003"/></geometry><material name="prop"/></visual>
    <visual><origin xyz="0.03 0 0" rpy="0 0 2.0944"/><geometry><box size="0.06 0.012 0.003"/></geometry><material name="prop"/></visual>
    <visual><origin xyz="0.03 0 0" rpy="0 0 4.1888"/><geometry><box size="0.06 0.012 0.003"/></geometry><material name="prop"/></visual>
  </link>
  <joint name="prop_back_joint" type="continuous">
    <parent link="thruster_back_body"/><child link="prop_back"/>
    <origin xyz="0.10 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
  </joint>

</robot>
