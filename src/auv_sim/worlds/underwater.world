            <joint name="auv::prop_R2_joint" velocity="60"/>
            <joint name="auv::prop_R3_joint" velocity="60"/>
            <joint name="auv::prop_back_joint" velocity="80"/>
          </plugin>
      -->

        </world>
      </sdf>

            <specular>0.02 0.02 0.02 1</specular>
          </material>
        </visual>
      </link>
    </model>


    <!-- <plugin name="joint_controller_1" filename="libgz-sim8-joint-controller-system.so">
      <joint name="auv::prop_L1_joint" velocity="60"/>
      <joint name="auv::prop_L2_joint" velocity="60"/>
